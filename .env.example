# ArkaDex — Environment Variables Template
# Copy to .env.local and fill in actual values. NEVER commit .env.local.
# Last updated: T1.2 Phase A

# Supabase (T1.1) — from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-jwt>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-jwt>

# Google OAuth via Supabase Auth (T1.2 Phase A)
# Consumed by `supabase start` (config.toml env() substitution). NOT read by Next.js.
# Source: Google Cloud Console > Credentials > ArkaDex Supabase
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=<google-oauth-client-id>
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=<google-oauth-client-secret>

# Admin Tier 3 gate (T1.2 Phase A+B) — server-side only, never NEXT_PUBLIC_
ADMIN_EMAIL_WHITELIST=your-admin-email@gmail.com
